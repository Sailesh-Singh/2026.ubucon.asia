---
import Navigation from "./Navigation.astro";
import { getHeroCtas, getSiteMetadata } from "../config/site";
import { getLocalizedPath, useTranslations } from "../i18n/ui";
import HeroImage from "../assets/uca25photo.png";
import BoothImage from "../assets/booth.jpg";
import PrimesessionImage from "../assets/primesession.jpg";
import SpeakerImage from "../assets/speaker.jpg";
const { locale } = Astro.props;
const t = useTranslations(locale) as (key: string) => string;
const metadata = getSiteMetadata(locale);
const heroCtas = getHeroCtas(locale);
---

<main>
    <Navigation locale={locale} />

    <section class="p-section--hero p-strip is-dark">
        <div class="row--50-50-on-large">
            <div class="col">
                <h1 class="u-no-margin--bottom">
                    {metadata.title}<br />
                    {metadata.subtitle}
                </h1>
                <p class="p-heading--2">
                    {metadata.date}
                </p>
                <p class="p-heading--2">
                    {metadata.venue}
                </p>
            </div>
            <div class="col">
                <div class="p-section--shallow">
                    <p>
                        {t("heroDescriptionPrimary")}
                    </p>
                    <p>
                        {t("heroDescriptionSecondary")}
                    </p>
                </div>

                <div class="p-section--shallow">
                    <div class="p-cta-block u-no-padding--bottom">
                        {
                            heroCtas.map((cta, index) => (
                                <a class="p-button--positive" href={cta.href}>
                                    {cta.label}
                                </a>
                            ))
                        }
                    </div>
                </div>
            </div>
            <div>
                <div class="p-image-container--cinematic is-cover">
                    <img
                        class="p-image-container__image"
                        src={HeroImage.src}
                        alt="alt-text"
                    />
                </div>
            </div>
        </div>
    </section>
    <div class="p-section p-strip is-dark" id="3-columns-responsive">
        <hr class="p-rule is-fixed-width" />
        <div class="p-section--shallow">
            <div class="grid-row--50-50-on-large">
                <div class="grid-col">
                    <h2>{t("contributeTitle")}</h2>
                </div>
                <div class="grid-col">
                    <p class="p-heading--5">
                        {t("contributeDescription")}
                    </p>
                </div>
            </div>
        </div>

        <div class="grid-row">
            <div class="grid-col-6 grid-col-start-large-3">
                <div class="p-equal-height-row--wrap">
                    <div class="p-equal-height-row__col is-borderless">
                        <div class="p-equal-height-row__item">
                            <div
                                class="p-image-container p-image-container--square-on-small p-image-container--square-on-medium p-image-container--2-3-on-large is-cover"
                            >
                                <img
                                    src={SpeakerImage.src}
                                    class="p-image-container__image"
                                    width="284"
                                    height="426"
                                    alt="Kernelt"
                                />
                            </div>
                            <hr class="p-rule--highlight" />
                        </div>
                        <div class="p-equal-height-row__item">
                            <p class="p-heading--5">
                                {t("contributeSpeakerTitle")}
                            </p>
                        </div>
                        <div class="p-equal-height-row__item">
                            <p>{t("contributeSpeakerDescription")}</p>
                        </div>
                        <div class="p-equal-height-row__item">
                            <p>
                                <a href="/cfp"
                                    >{t("contributeSpeakerLinkLabel")}&nbsp;›</a
                                >
                            </p>
                        </div>
                    </div>
                    <div class="p-equal-height-row__col is-borderless">
                        <div class="p-equal-height-row__item">
                            <div
                                class="p-image-container p-image-container--square-on-small p-image-container--square-on-medium p-image-container--2-3-on-large is-cover"
                            >
                                <img
                                    src={PrimesessionImage.src}
                                    class="p-image-container__image"
                                    width="284"
                                    height="426"
                                    alt="Kernelt"
                                />
                            </div>
                            <hr class="p-rule--highlight" />
                        </div>
                        <div class="p-equal-height-row__item">
                            <p class="p-heading--5">
                                {t("contributePrimeTitle")}
                            </p>
                        </div>
                        <div class="p-equal-height-row__item">
                            <p>{t("contributePrimeDescription")}</p>
                        </div>
                        <div class="p-equal-height-row__item">
                            <p>
                                <a
                                    href="https://discourse.ubuntu.com/t/call-for-nominations-ubucon-asia-2026-coscup-prime-session-speaker/78309"
                                    >{t("contributePrimeLinkLabel")}&nbsp;›</a
                                >
                            </p>
                        </div>
                    </div>
                    <div class="p-equal-height-row__col is-borderless">
                        <div class="p-equal-height-row__item">
                            <div
                                class="p-image-container p-image-container--square-on-small p-image-container--square-on-medium p-image-container--2-3-on-large is-cover"
                            >
                                <img
                                    src={BoothImage.src}
                                    class="p-image-container__image"
                                    width="284"
                                    height="426"
                                    alt="Kernelt"
                                />
                            </div>
                            <hr class="p-rule--highlight" />
                        </div>
                        <div class="p-equal-height-row__item">
                            <p class="p-heading--5">
                                {t("contributeBoothTitle")}
                            </p>
                        </div>
                        <div class="p-equal-height-row__item">
                            <p>{t("contributeBoothDescription")}</p>
                        </div>
                        <div class="p-equal-height-row__item">
                            <p>
                                <a
                                    href="https://discourse.ubuntu.com/t/call-for-booth-volunteers-ubucon-asia-2026-coscup/78729"
                                    >{t("contributeBoothLinkLabel")}&nbsp;›</a
                                >
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
